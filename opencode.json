{
  "$schema": "https://opencode.ai/config.json",
  "model": "anthropic/claude-sonnet-4-5",
  "small_model": "anthropic/claude-haiku-4-5",
  "autoupdate": true,
  "instructions": [
    "AGENTS.md",
    "wiki/README.md"
  ],
  "mcp": {
    "mem0": {
      "type": "local",
      "command": ["uvx", "mem0-mcp-server"],
      "environment": {
        "MEM0_API_KEY": "{env:MEM0_API_KEY}",
        "MEM0_DEFAULT_USER_ID": "lbruton"
      }
    },
    "sequential-thinking": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-sequential-thinking"]
    },
    "brave-search": {
      "type": "local",
      "command": ["npx", "-y", "@brave/brave-search-mcp-server"],
      "environment": {
        "BRAVE_API_KEY": "{env:BRAVE_API_KEY}"
      }
    },
    "claude-context": {
      "type": "local",
      "command": ["npx", "-y", "@zilliz/claude-context-mcp@latest"],
      "environment": {
        "OPENAI_API_KEY": "{env:OPENAI_API_KEY}",
        "MILVUS_TOKEN": "{env:MILVUS_TOKEN}"
      },
      "timeout": 30000
    },
    "codacy": {
      "type": "local",
      "command": ["npx", "-y", "@codacy/codacy-mcp"],
      "environment": {
        "CODACY_ACCOUNT_TOKEN": "{env:CODACY_ACCOUNT_TOKEN}"
      },
      "timeout": 30000
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "code-graph-context": {
      "type": "local",
      "command": ["docker", "exec", "-i", "cgc-server", "cgc", "mcp", "start"]
    },
    "firecrawl-local": {
      "type": "local",
      "command": ["npx", "-y", "firecrawl-mcp"],
      "environment": {
        "FIRECRAWL_API_URL": "http://localhost:3002",
        "FIRECRAWL_API_KEY": "fc-local-dev"
      }
    },
    "infisical": {
      "type": "local",
      "command": ["npx", "-y", "@infisical/mcp"],
      "environment": {
        "INFISICAL_HOST_URL": "http://192.168.1.47:8080",
        "INFISICAL_UNIVERSAL_AUTH_CLIENT_ID": "{env:INFISICAL_UNIVERSAL_AUTH_CLIENT_ID}",
        "INFISICAL_UNIVERSAL_AUTH_CLIENT_SECRET": "{env:INFISICAL_UNIVERSAL_AUTH_CLIENT_SECRET}"
      }
    }
  },
  "agent": {
    "code-reviewer": {
      "description": "Reviews code for StakTrakr patterns and quality",
      "model": "anthropic/claude-sonnet-4-5",
      "prompt": "You are a code reviewer for StakTrakr, a vanilla JS single-page app. Enforce: safeGetElement() for DOM access, saveData()/loadData() for storage, sanitizeHtml() for user content, ALLOWED_STORAGE_KEYS whitelist, correct script load order in index.html. No frameworks, no build step, no ES modules.",
      "tools": {
        "write": false,
        "edit": false
      }
    }
  },
  "command": {
    "lint": {
      "template": "Run eslint on all JS files: npx eslint js/*.js sw.js",
      "description": "Lint all JavaScript files",
      "agent": "build"
    },
    "serve": {
      "template": "Start a local dev server: python3 -m http.server 8000",
      "description": "Start local HTTP server on port 8000",
      "agent": "build"
    },
    "health": {
      "template": "Check API feed freshness: curl -s https://api.staktrakr.com/data/api/manifest.json | head -5 && curl -s https://api.staktrakr.com/data/api/goldback-spot.json | head -3",
      "description": "Quick API health check",
      "agent": "build"
    }
  }
}
